# ============================================================
# RuneScape: Dragonwilds Dedicated Server Configuration
# ============================================================
# Copy this file to .env and fill in the values below.

# REQUIRED: Your RuneScape: Dragonwilds Player ID.
# Found in-game at the bottom of the Settings Menu.
OWNER_ID=YOUR_PLAYER_ID_HERE

# REQUIRED: The name of your server (visible in the public server list).
SERVER_NAME=My Dragonwilds Server

# REQUIRED: The default world name created on first startup.
DEFAULT_WORLD_NAME=DefaultWorld

# REQUIRED: Admin password for the Server Management menu.
ADMIN_PASSWORD=changeme

# OPTIONAL: World password. Leave empty for a public server.
WORLD_PASSWORD=

# OPTIONAL: UDP port the server listens on (default 7777).
SERVER_PORT=7777
